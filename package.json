{
  "name": "linketry",
  "version": "0.10.4",
  "description": "Linketry is a self-hosted link management, analytics and monitoring platform.",
  "author": "everettlabs",
  "homepage": "https://linketry.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/everett7623/Linketry.git"
  },
  "license": "GPL-3.0-only",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:worker": "npm run dev --workspace=apps/worker",
    "dev:admin": "npm run dev --workspace=apps/admin",
    "build:admin": "npm run build --workspace=apps/admin",
    "test:admin": "npm run test --workspace=apps/admin",
    "test:worker": "npm run test --workspace=apps/worker",
    "deploy:worker": "npm run deploy --workspace=apps/worker",
    "db:migrate:local": "npm run db:migrate:local --workspace=apps/worker",
    "db:migrate:remote": "npm run db:migrate:remote --workspace=apps/worker"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "prettier": "^3.3.3",
    "eslint": "^9.8.0"
  }
}
