# Copy this file to apps/worker/wrangler.toml, then replace every
# <placeholder> with values from your own Cloudflare account.

name = "linkora-worker"
main = "src/index.ts"
compatibility_date = "2026-07-08"
compatibility_flags = ["nodejs_compat"]

# Short/API domain. This Worker serves redirects and /api/*.
# Example: go.example.com or s.example.com
routes = [
  { pattern = "<your-short-domain>", custom_domain = true }
]

[vars]
LINKORA_VERSION = "0.7.3"

[[d1_databases]]
binding = "DB"
database_name = "linkora-db"
database_id = "<your-d1-database-id>"
migrations_dir = "../../migrations"

[[kv_namespaces]]
binding = "KV"
id = "<your-kv-namespace-id>"
preview_id = "<your-kv-preview-id>"

[[r2_buckets]]
binding = "BACKUPS"
bucket_name = "linkora-backups"
preview_bucket_name = "linkora-backups-dev"

[[queues.producers]]
binding = "VISITS_QUEUE"
queue = "linkora-visits"

[[queues.consumers]]
queue = "linkora-visits"
max_batch_size = 10
max_batch_timeout = 5

[triggers]
# Cloudflare cron uses UTC. 18:00 UTC is 02:00 in Asia/Shanghai.
crons = ["0 18 * * *"]

# Secrets are set outside this file:
#   cd apps/worker
#   npx wrangler secret put ADMIN_TOKEN
