# Copy this file to apps/worker/wrangler.toml, then replace every
# <placeholder> with values from your own Cloudflare account.

name = "linkora-worker"
main = "src/index.ts"
compatibility_date = "2026-07-08"
compatibility_flags = ["nodejs_compat"]

# Basic deployment: use one domain for both short links and /api/*.
# Advanced deployment: add a second domain when API isolation or migration requires it.
routes = [
  { pattern = "<your-short-domain>", custom_domain = true }
]

[vars]
LINKORA_VERSION = "0.9.10"

[[d1_databases]]
binding = "DB"
database_name = "linkora-db"
database_id = "<your-d1-database-id>"
migrations_dir = "../../migrations"

[[kv_namespaces]]
binding = "KV"
id = "<your-kv-namespace-id>"
preview_id = "<your-kv-preview-id>"

[triggers]
crons = ["0 18 * * *"]

# Advanced optional bindings are documented in docs/SELF_HOSTING.md:
# - R2 enables scheduled backups and one-click restore.
# - Queue enables asynchronous visit processing.
# - Additional custom domains enable separate API and public short-link hosts.

# Secrets are set outside this file:
#   cd apps/worker
#   npx wrangler secret put ADMIN_TOKEN
