{
  "name": "@linkora/worker",
  "version": "0.7.3",
  "license": "GPL-3.0-only",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply linkora-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply linkora-db --remote",
    "db:create": "wrangler d1 create linkora-db",
    "kv:create": "wrangler kv namespace create LINKORA_KV",
    "queue:create": "wrangler queues create linkora-visits --message-retention-period-secs 60",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@linkora/shared": "*",
    "hono": "^4.5.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240725.0",
    "typescript": "^5.4.5",
    "wrangler": "^3.65.1"
  }
}
