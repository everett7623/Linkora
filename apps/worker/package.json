{
  "name": "@linkora/worker",
  "version": "0.8.7",
  "license": "GPL-3.0-only",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply linkora-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply linkora-db --remote",
    "db:create": "wrangler d1 create linkora-db",
    "kv:create": "wrangler kv namespace create LINKORA_KV",
    "queue:create": "wrangler queues create linkora-visits --message-retention-period-secs 60",
    "type-check": "tsc --noEmit",
    "test": "node --experimental-strip-types --test src/utils/publicPages.test.mjs src/backups/retention.test.mjs src/health/monitoringPolicy.test.mjs src/links/fallbackUrl.test.mjs src/analytics/botDetection.test.mjs"
  },
  "dependencies": {
    "@linkora/shared": "*",
    "hono": "^4.5.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240725.0",
    "typescript": "^5.4.5",
    "wrangler": "^3.65.1"
  }
}
