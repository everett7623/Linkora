# =============================================================================
# Linketry — Environment Variable Reference
# =============================================================================
# This file documents ALL environment variables used across the project.
# Copy and fill in values as required for each environment.
#
# Worker secrets:  apps/worker/.dev.vars  (local)
#                  `wrangler secret put <KEY>`  (production)
#
# Admin frontend:  apps/admin/.env  (local override, optional)
#                  set at build time or via hosting platform (production)
# =============================================================================


# -----------------------------------------------------------------------------
# WORKER — Secrets (apps/worker/.dev.vars or wrangler secrets)
# -----------------------------------------------------------------------------

# Admin API bearer token. All /api/v1/* requests must supply:
#   Authorization: Bearer <LINKETRY_ADMIN_TOKEN>
# Use a long random string. Never commit the real value.
LINKETRY_ADMIN_TOKEN=replace-with-a-long-random-secret

# Optional one-click upgrade token. Create a fine-grained GitHub token restricted
# to this deployment repository with Actions: write, then store it as a Worker
# secret. Never expose this value through a VITE_* variable.
LINKETRY_GITHUB_UPDATE_TOKEN=replace-with-actions-write-token


# -----------------------------------------------------------------------------
# WORKER — Optional Variables (wrangler.toml [vars] section)
# -----------------------------------------------------------------------------

# Displayed in /health and About section of the admin panel.
# Defaults to the package version if not set.
LINKETRY_VERSION=0.26.2

# Scheduled task routing. Cron expressions are UTC.
LINKETRY_DAILY_CRON=0 18 * * *
LINKETRY_HEALTH_CRON=0 * * * *

# Fixed online-upgrade target. GitHub Actions fills these from the current fork.
LINKETRY_UPDATE_REPOSITORY=owner/linketry-fork
LINKETRY_UPDATE_BRANCH=main


# -----------------------------------------------------------------------------
# WORKER — Cloudflare Resource Bindings (wrangler.toml)
# -----------------------------------------------------------------------------
# These are NOT environment variables — they are configured in wrangler.toml.
# Listed here for reference.
#
# [[d1_databases]]
# binding = "DB"
# database_name = "linketry"
# database_id = "<your-d1-database-id>"    ← from: npm run deploy:bootstrap
#
# [[kv_namespaces]]
# binding = "KV"
# id = "<your-kv-namespace-id>"            ← from: npm run deploy:bootstrap
# preview_id = "<your-kv-preview-id>"      ← optional manual preview namespace
#
# [[r2_buckets]]
# binding = "BACKUPS"
# bucket_name = "linketry-backups"          ← from: wrangler r2 bucket create linketry-backups
# preview_bucket_name = "linketry-backups-dev"
#
# [[queues.producers]]
# binding = "VISITS_QUEUE"
# queue = "linketry-visits"                ← from: wrangler queues create linketry-visits --message-retention-period-secs 60
#
# [[queues.consumers]]
# queue = "linketry-visits"
# max_batch_size = 10
# max_batch_timeout = 5
#
# [triggers]
# crons = ["0 18 * * *"]                  ← daily backup at 02:00 Asia/Shanghai


# -----------------------------------------------------------------------------
# ADMIN FRONTEND — Build-time Variables (apps/admin/.env or hosting env)
# -----------------------------------------------------------------------------

# Base URL for the admin frontend to reach the Worker API.
# In local dev (vite.config.ts proxy is active), leave this empty.
# In production, set to the Worker URL if admin and worker are on different domains.
# Example: https://go.example.com
VITE_LINKETRY_API_URL=

# Repository that owns this deployment's protected online-upgrade workflow.
# GitHub Actions fills this automatically. Set it only for another hosting platform.
VITE_LINKETRY_REPOSITORY_URL=https://github.com/your-account/Linketry
VITE_LINKETRY_UPDATE_BRANCH=main
VITE_LINKETRY_DEMO_ACCESS_CODE=LinketryDemo

# Optional GitHub Actions repository variable used only when a branded Admin
# domain has been added under the Cloudflare Pages project's Custom domains.
# Leave empty to use https://<LINKETRY_PAGES_PROJECT>.pages.dev automatically.
# Example: https://admin.example.com
LINKETRY_ADMIN_URL=

# Optional official project-site deployment. These are GitHub Actions repository
# variables, not Worker runtime values.
LINKETRY_SITE_PROJECT=linketry-site
LINKETRY_SITE_URL=https://linketry.com


# -----------------------------------------------------------------------------
# GITHUB ACTIONS — Deployment Gate Repository Variables (not Worker runtime)
# -----------------------------------------------------------------------------

# Bind each production run to one reviewed track, release, commit, and migration
# set. Generate the digest with: npm run deploy:migration-digest
LINKETRY_DEPLOYMENT_TRACK=fresh
LINKETRY_APPROVED_RELEASE=0.26.2
LINKETRY_APPROVED_COMMIT=<40-character-git-commit-sha>
LINKETRY_APPROVED_MIGRATIONS_SHA256=<migration-digest>
LINKETRY_FRESH_INSTALL_CONFIRMED=true

# Before later deployments, switch the track to upgrade and follow
# docs/DEPLOYMENT_PREFLIGHT.md for the backup and migration-review gates.


# -----------------------------------------------------------------------------
# GITHUB ACTIONS — Isolated Demo Environment (not production runtime)
# -----------------------------------------------------------------------------

# Configure these only inside the protected `linketry-demo` GitHub environment.
# The Demo Cloudflare token and account must have no production write access.
LINKETRY_DEMO_CREDENTIAL_SCOPE_CONFIRMED=true
LINKETRY_DEMO_ISOLATION_CONFIRMED=true
LINKETRY_DEMO_SYNTHETIC_DATA_ONLY=true
LINKETRY_DEMO_APPROVED_RELEASE=0.26.2
LINKETRY_DEMO_APPROVED_COMMIT=<40-character-git-commit-sha>
LINKETRY_DEMO_APPROVED_MIGRATIONS_SHA256=<migration-digest>
LINKETRY_DEMO_WORKER_NAME=linketry-demo-worker
LINKETRY_DEMO_USE_WORKERS_DEV=true
LINKETRY_DEMO_WORKER_DOMAINS=linketry-demo-worker.<demo-account-subdomain>.workers.dev
LINKETRY_DEMO_API_URL=https://linketry-demo-worker.<demo-account-subdomain>.workers.dev
LINKETRY_DEMO_ADMIN_URL=https://demo.linketry.com
LINKETRY_DEMO_PAGES_PROJECT=linketry-demo-admin
LINKETRY_DEMO_D1_DATABASE_NAME=linketry-demo-d1
LINKETRY_DEMO_D1_DATABASE_ID=<isolated-demo-d1-id>
LINKETRY_DEMO_KV_NAMESPACE_ID=<isolated-demo-kv-id>
LINKETRY_DEMO_R2_BUCKET=linketry-demo-backups
LINKETRY_DEMO_R2_PREVIEW_BUCKET=linketry-demo-backups-preview
LINKETRY_DEMO_VISITS_QUEUE=linketry-demo-visits
LINKETRY_DEMO_COMPATIBILITY_DATE=2026-07-16
LINKETRY_PROTECTED_ACCOUNT_IDS=<comma-separated-production-account-ids>
LINKETRY_PROTECTED_RESOURCE_IDS=<comma-separated-production-d1-kv-ids>
LINKETRY_PROTECTED_RESOURCE_NAMES=<comma-separated-production-resource-names>
LINKETRY_PROTECTED_DOMAINS=<comma-separated-production-hostnames>


# -----------------------------------------------------------------------------
# NOTES
# -----------------------------------------------------------------------------
#
# Local development:
#   1. Copy this file: cp .env.example apps/worker/.dev.vars
#   2. Set LINKETRY_ADMIN_TOKEN to any test value
#   3. The admin frontend reads VITE_LINKETRY_API_URL at build time; for local dev
#      the Vite proxy (vite.config.ts) forwards /api → http://localhost:8787
#
# Production deployment:
#   wrangler secret put LINKETRY_ADMIN_TOKEN
#   → prompts for the value, stores it encrypted in Cloudflare
#
# Never commit real tokens or secrets to Git.
# The .dev.vars file is in .gitignore.
